# =============================================================================
# Market Warehouse — Configuration
# =============================================================================
# Copy this file to .env and fill in your secrets.
# Never commit .env to version control.
# =============================================================================

# ── Angel One SmartAPI ────────────────────────────────────────────────────────
ANGEL_API_KEY=
ANGEL_CLIENT_CODE=
ANGEL_PASSWORD=
ANGEL_TOTP_SECRET=

# ── NSE Watchlist ─────────────────────────────────────────────────────────────
# Comma-separated list of Angel One token IDs for symbols to track
NSE_TOKENS=2885,3045,1333,11536
# 2885 = RELIANCE, 3045 = SBIN, 1333 = INFY, 11536 = TCS

# ── Storage ───────────────────────────────────────────────────────────────────
DATA_DIR=data

# ── Cleaning ──────────────────────────────────────────────────────────────────
OUTLIER_Z_THRESHOLD=4.0
GAP_FILL_MAX_BARS=2

# ── Behaviour ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
TIMEZONE=Asia/Kolkata
